    <MicrosoftCodeAnalysisCommonVersion>3.5.0</MicrosoftCodeAnalysisCommonVersion>
    <MicrosoftCodeAnalysisWorkspacesCommonVersion>3.5.0</MicrosoftCodeAnalysisWorkspacesCommonVersion>
    <MicrosoftSourceLinkGitHubVersion>1.0.0</MicrosoftSourceLinkGitHubVersion>
    
    <MonoCecilVersion>0.11.2</MonoCecilVersion>
    <NewtonsoftJsonVersion>12.0.3</NewtonsoftJsonVersion>
    <SystemReflectionMetadataVersion>1.8.1</SystemReflectionMetadataVersion>

    <MicrosoftExtenionsGlobalVersion>3.1.7</MicrosoftExtenionsGlobalVersion>
